{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "description": "Standardized requirements for feats, traits, and classes",
    "properties": {
        "req_type": {
            "type": "string",
            "enum": [
                "ability_score",
                "base_attack_bonus",
                "feat",
                "skill_rank",
                "class_level",
                "race"
            ]
        },
        "target": {
            "type": "string",
            "description": "e.g., 'STR', 'power_attack', 'acrobatics', 'alchemist'"
        },
        "value": {
            "type": [
                "number",
                "string"
            ],
            "description": "e.g., 13 (for STR), or 'human' (for race)"
        }
    },
    "required": [
        "req_type",
        "target",
        "value"
    ]
}