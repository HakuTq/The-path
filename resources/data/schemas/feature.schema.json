{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "description": "Schema for Pathfinder class features",
    "patternProperties": {
        "^[a-z0-9_]+$": {
            "type": "object",
            "properties": {
                "label": {
                    "type": "string",
                    "description": "The display name of the feature"
                },
                "easy": {
                    "type": "string",
                    "description": "Short tooltip for the feature"
                },
                "type": {
                    "type": "string",
                    "enum": [
                        "extraordinary",
                        "supernatural",
                        "spell_like",
                        "passive"
                    ],
                    "description": "The Pathfinder ability type"
                },
                "description": {
                    "type": "string"
                },
                "effects": {
                    "type": "array",
                    "items": {
                        "$ref": "./effect.scheme.json"
                    },
                    "minItems": 1
                }
            },
            "required": [
                "type"
            ]
        }
    },
    "required": [
        "label",
        "type",
        "description",
        "easy"
    ],
    "additionalProperties": false
}