{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "description": "Schema for Pathfinder class feature effect",
    "properties": {
        "type": {
            "enum": [
                "bonus",
                "choice",
                "scaling",
                "immunity",
                "utility",
                "weapon",
                "feat"
            ]
        },
        "target": {
            "type": "string",
            "enum": [
                "saves_poison",
                "poison",
                "craft",
                "craft_alchemy",
                "fire_damage",
                "natural_armor",
                "physical_score",
                "combat",
                "class_feature",
                "duration"
            ]
        },
        "value": {
            "oneOf": [
                {
                    "type": "number"
                },
                {
                    "type": "string"
                },
                {
                    "$ref": "./scaling.scheme.json"
                }
            ]
        },
        "bonus_type": {
            "type": "string",
            "enum": [
                "alchemical",
                "armor",
                "circumstance",
                "competence",
                "deflection",
                "dodge",
                "enhancement",
                "insight",
                "luck",
                "morale",
                "natural",
                "profane",
                "racial",
                "resistance",
                "sacred",
                "shield",
                "size",
                "trait",
                "untyped"
            ]
        }
    },
    "required": [
        "type",
        "target",
        "value"
    ]
}