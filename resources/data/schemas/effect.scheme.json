{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "description": "Schema for Pathfinder class feature effect",
    "properties": {
        "type": {
            "enum": [
                "bonus",
                "choice",
                "scaling",
                "immunity",
                "utility",
                "weapon",
                "feat"
            ]
        },
        "target": {
            "type": "string"
        },
        "value": {
            "type": [
                "number",
                "string"
            ]
        },
        "bonus_type": {
            "type": "string",
            "enum": [
                "enhancment",
                "natural"
            ]
        }
    }
}